# Server
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,PATCH,DELETE

# Database (Supabase PostgreSQL)
DATABASE_URL=           # connection pooling (supabase pooler)
DIRECT_URL=             # direct connection (for migrations)

# Access Token (Paseto V4)
ACCESS_TOKEN_SECRET=example
ACCESS_TOKEN_PUBLIC=example

# Refresh Token (Paseto V4)
REFRESH_TOKEN_SECRET=example
REFRESH_TOKEN_PUBLIC=example
