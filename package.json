{
  "name": "simple-web-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "clean": "rimraf dist",
    "dev": "dotenv -e .env.development -- tsx watch src/index.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "generate:key": "tsx scripts/generate-key.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "start": "node dist/index.js",
    "start:prod": "dotenv -e .env.production -- node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "paseto": "^3.1.4",
    "pg": "^8.20.0",
    "winston": "^3.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
