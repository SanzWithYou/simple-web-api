{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./",
    "outDir": "./dist",

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,

    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*", "prisma.config.ts", "prisma/schema.prisma"],
  "exclude": ["node_modules", "dist"]
}
